# ───────────────────────────────────────────────
# 이 파일을 복사해 .env 로 만들거나, Vercel 프로젝트의
# Environment Variables 화면에 그대로 입력하세요.
# .env 파일은 절대 깃허브에 올리지 마세요(.gitignore에 이미 등록됨).
# ───────────────────────────────────────────────

# [필수] OpenAI API 키 — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# [선택] 사용할 모델 (기본값: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# [선택 — 저장 기능을 쓸 때만] Supabase 연결
# Supabase 프로젝트 > Settings > Data API / API Keys 에서 확인
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role 키 (절대 외부 노출 금지)
